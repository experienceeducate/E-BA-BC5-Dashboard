# BigQuery — point to your downloaded service account key file
GOOGLE_SERVICE_ACCOUNT_KEY=~/key.json

# BigQuery table config (BC5 feed not live yet — see docs/CONTEXT.md)
BQ_PROJECT_ID=educate-data-warehouse-test
BQ_DATASET=gold_eba
BQ_TABLE=eba_recruitment_funnel

# Custom client-header token (frontend must send X-EBA-Client: <this value>)
EBA_CLIENT_TOKEN=eba-dashboard-v1

# Guest auth (shared password)
DASHBOARD_PASSWORD=your_strong_password_here

# JWT signing (also used as the Starlette session secret for OAuth state)
JWT_SECRET=your_long_random_secret_here

# Youth pseudonym salt. Leak makes raw identifiers re-linkable from youth_ids.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
EBA_ID_SALT=your_long_random_salt_here

# Google SSO (staff auth). Leave blank to disable SSO; guest password still works.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
OAUTH_ALLOWED_DOMAIN=experienceeducate.org

# Frontend origin — OAuth callback redirects here with the JWT in a URL fragment.
FRONTEND_URL=http://localhost:3000
