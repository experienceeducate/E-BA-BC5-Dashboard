# Copy to .env.local for local dev (Vite prefers .env.local over .env).
# ⚠️ Do NOT create frontend/.env — a stale one has previously made local dev
# silently hit production. Use .env.local ONLY.
VITE_API_URL=http://localhost:8000

# Optional: override the client-header token (must match backend EBA_CLIENT_TOKEN).
# VITE_CLIENT_TOKEN=eba-dashboard-v1
